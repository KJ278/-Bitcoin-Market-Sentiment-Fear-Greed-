{
  "manifest_version": 3,
  "name": "EventHub",
  "description": "Discover events from BookMyShow, Insider, and District in one popup dashboard.",
  "version": "1.1.0",
  "permissions": ["storage", "scripting", "alarms"],
  "host_permissions": [
    "https://in.bookmyshow.com/*",
    "https://insider.in/*",
    "https://district.in/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "EventHub",
    "default_popup": "popup.html"
  }
}
